# LLM API Configuration (supports any LLM API compatible with the OpenAI SDK format)
# Recommended: OpenAI GPT-4 or any OpenAI-compatible API: https://platform.openai.com/
# Note: token consumption can be high; try simulations with fewer than 40 rounds first
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL_NAME=gpt-4

# ===== ZEP Memory Graph Configuration =====
# The free monthly quota is sufficient for simple usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM Configuration (Optional) =====
# Note: if you are not using the boost configuration, do not include these entries in the .env file
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
